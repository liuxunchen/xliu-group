        self.molecules = [m for m in self.molecules if m['name'] != mol_name]
        self.molecules.append({'name': mol_name, 'lines': lines, 'conc': concentration})

    def _load_par_file(self, filepath, target_mol_id=None):
        lines = []
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                # 【修复】放宽长度限制，兼容各种 HITRAN/HITEMP 格式
                if len(line) < 65: continue 
                try:
                    mol_id = int(line[0:2].strip())
                    if target_mol_id is not None and mol_id != target_mol_id: 
                        continue
                    
                    lines.append({
                        'molecule_id': mol_id,
                        'iso_id': int(line[2:3].strip()), # 同位素编号
                        'v0': float(line[3:15].strip()),
                        'sw': float(line[15:25].strip()),
                        'gamma_air': float(line[35:40].strip()),
                        'n_air': float(line[50:54].strip()),
                        'elower': float(line[55:65].strip())
                    })
                except (ValueError, IndexError):
                    continue
        return lines

    def calculate_spectrum(self, wn_start, wn_end, T, p, l, resolution=0.01, omega_wing=25.0):
        if not self.molecules:
            raise ValueError(\"No molecules added.\")

        wavenumber = np.arange(wn_start, wn_end, resolution)
        total_coef = np.zeros_like(wavenumber)
        individual_coefs = {}
        
