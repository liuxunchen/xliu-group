        wn_end = self.end_spin.value() if not self.use_default_check.isChecked() else None
        res = self.resolution_spin.value()

        self.progress_bar.setVisible(True)
        self.progress_bar.setValue(0)
        self.ax.clear()
        
        total_absorbance = None
        wavenumbers = None
        stats_msg = \"<b>混合气体光谱计算结果:</b><br>\"
        
        total_files = self.par_file_list.count()
        
        for i in range(total_files):
            par_file = self.par_file_list.item(i).text()
            file_name = os.path.basename(par_file)
            self.log(f\"正在处理: {file_name} ...\")
            
            # 【智能浓度匹配】
            # 尝试从文件名或 Cantera 传来的组分中匹配浓度 (ppm)
            # 假设文件名包含分子式，如 \"H2O.par\", \"CO2.par\"
            mol_name = os.path.splitext(file_name)[0].split('_')[0] # 提取 H2O, CO2 等
            
            # 默认浓度 10 ppm，如果能从 Cantera 结果中找到，则自动替换
            concentration_ppm = 10.0 
            if self.cantera_species:
                for sp, frac in self.cantera_species.items():
                    if mol_name.upper() in sp.upper() or sp.upper() in mol_name.upper():
                        concentration_ppm = float(frac * 1e6)
                        break
            
