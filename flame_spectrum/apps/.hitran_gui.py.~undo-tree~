                mol_coef += sw_T * N_total * c * profile * c_light
                
            individual_coefs[mol['name']] = mol_coef
            total_coef += mol_coef

        transmittance = np.exp(-total_coef * l)
        
        return {
            'wavenumber': wavenumber, 'total_coef': total_coef,
            'individual_coefs': individual_coefs, 'Tr': transmittance,
            'params': {'T': T, 'p': p, 'l': l, 'wn_range': (wn_start, wn_end), 'omega_wing': omega_wing}
        }

