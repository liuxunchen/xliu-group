    # ================= 文件选择与波数范围自动识别 =================
    def add_par_files(self):
        filenames, _ = QFileDialog.getOpenFileNames(
            self, \"选择 HITRAN .par 文件 (可多选)\", self.db_path, \"PAR Files (*.par);;All Files (*)\"
        )
        if filenames:
            existing = [self.par_file_list.item(i).text() for i in range(self.par_file_list.count())]
            for f in filenames:
                if f not in existing:
                    self.par_file_list.addItem(f)
                    # 读取文件并更新全局波数范围
                    self.update_wn_range_from_par(f)
                    
            # 自动将 UI 中的波数范围设置为文件的极值
            if self.global_min_wn != float('inf'):
                self.start_spin.setValue(self.global_min_wn)
                self.end_spin.setValue(self.global_max_wn)
                self.log(f\"已自动更新波数范围: {self.global_min_wn:.2f} - {self.global_max_wn:.2f} cm^-1\")

    def update_wn_range_from_par(self, par_file):
        \"\"\"解析 HITRAN .par 文件的前 15 个字符获取波数，更新全局极值\"\"\"
        try:
            with open(par_file, 'r') as f:
                for line in f:
                    if len(line) >= 15:
                        try:
                            # HITRAN 格式：第 3-15 列是 wavenumber (nu)
                            wn = float(line[3:15].strip())
                            if wn < self.global_min_wn: self.global_min_wn = wn
                            if wn > self.global_max_wn: self.global_max_wn = wn
                        except ValueError:
                            continue
        except Exception as e:
            self.log(f\"警告: 无法读取 {os.path.basename(par_file)} 的波数范围 ({e})\")

    def remove_selected_par(self):
        for item in self.par_file_list.selectedItems():
            self.par_file_list.takeItem(self.par_file_list.row(item))
        # 如果列表空了，重置范围
        if self.par_file_list.count() == 0:
            self.global_min_wn = float('inf')
            self.global_max_wn = 0.0

    def select_q_folder(self):
        folder = QFileDialog.getExistingDirectory(self, \"选择配分函数文件夹\", self.db_path)
        if folder:
            self.q_folder_edit.setText(folder)

    def log(self, msg):
        self.info_text.append(msg)

    # ================= 混合气体计算与双轴绘图逻辑 =================
    def calculate_mixture(self):
        if self.par_file_list.count() == 0:
            QMessageBox.warning(self, \"警告\", \"请至少添加一个 .par 文件！\")
            return

        T = self.temp_spin.value()
        P = self.pressure_spin.value()
        L = self.path_spin.value()
        omega_wing = self.omega_wing_spin.value() # 获取 Omega Wing 参数
        
        wn_start = self.start_spin.value()
        wn_end = self.end_spin.value()
        res = self.resolution_spin.value()

        self.progress_bar.setVisible(True)
        self.progress_bar.setValue(0)
        
        # 【核心】清空并重建双X双Y轴
        self.fig.clear()
        ax1 = self.fig.add_subplot(111) # 主坐标轴 (X: 波数, Y: 透过率)
        
        total_absorbance = None
        wavenumbers = np.arange(wn_start, wn_end, res)
        stats_msg = \"<b>混合气体光谱计算结果:</b><br>\"
        
        total_files = self.par_file_list.count()
        
        for i in range(total_files):
            par_file = self.par_file_list.item(i).text()
            file_name = os.path.basename(par_file)
            self.log(f\"正在处理: {file_name} (Wing: {omega_wing} cm^-1)...\")
            
            mol_name = os.path.splitext(file_name)[0].split('_')[0] 
            
            # 智能浓度匹配
            concentration_ppm = 10.0 
            if self.cantera_species:
                for sp, frac in self.cantera_species.items():
                    if mol_name.upper() in sp.upper() or sp.upper() in mol_name.upper():
                        concentration_ppm = float(frac * 1e6)
                        break
            
            try:
                # ==========================================================
                # 【注意】请在此处替换为您真实的 HitranSpectrum 核心调用！
                # 伪代码演示如何传入 omega_wing
                # hitran = HitranSpectrum(par_file, self.q_folder_edit.text())
                # hitran.load_data()
                # abs_coeff = hitran.calculate(T, P, concentration_ppm, wn_start, wn_end, res, wing_cutoff=omega_wing)
                
                # --- 伪代码占位 ---
                peak_center = (wn_start + wn_end) / 2 + (i * 50) 
                abs_coeff = np.exp(-((wavenumbers - peak_center)**2) / 100) * (concentration_ppm / 100) 
                # ------------------

                if total_absorbance is None:
                    total_absorbance = abs_coeff * L
                else:
                    total_absorbance += abs_coeff * L

                stats_msg += f\"- <b>{mol_name}</b>: {concentration_ppm:.2f} ppm<br>\"
                
            except Exception as e:
                self.log(f\"错误: 处理 {file_name} 失败 -> {str(e)}\")

            self.progress_bar.setValue(int((i + 1) / total_files * 100))

        if total_absorbance is not None:
            # 计算透过率 (Transmittance = exp(-Absorbance))
            transmittance = np.exp(-total_absorbance)
            
            # ================= 【复习】双 X 双 Y 轴绘图格式 =================
            # 1. 主 Y 轴 (左侧): 透过率 (Transmittance)
            ax1.plot(wavenumbers, transmittance, 'b-', linewidth=1.5, label=\"Transmittance (Total)\")
            ax1.set_xlabel(\"Wavenumber (cm$^{-1}$)\", color='black', fontsize=12)
            ax1.set_ylabel(\"Transmittance\", color='blue', fontsize=12)
            ax1.tick_params(axis='y', labelcolor='blue')
            ax1.set_ylim(0, 1.1)
            
            # 2. 副 Y 轴 (右侧): 吸收系数 / 吸光度 (Absorbance)
            ax2 = ax1.twinx()
            ax2.plot(wavenumbers, total_absorbance, 'r--', linewidth=1.5, alpha=0.7, label=\"Absorbance (Total)\")
            ax2.set_ylabel(\"Absorbance / Abs. Coeff\", color='red', fontsize=12)
            ax2.tick_params(axis='y', labelcolor='red')
            
            # 3. 副 X 轴 (顶部): 波长 (Wavelength in \\mu m)
            # 使用 secondary_xaxis 进行非线性转换 (lambda = 10000 / nu)
            def forward_wn_to_wl(x):
                # 防止除以 0
                x = np.where(x == 0, 1e-10, x)
                return 10000.0 / x
            def backward_wl_to_wn(x):
                x = np.where(x == 0, 1e-10, x)
                return 10000.0 / x

            ax3 = ax1.secondary_xaxis('top', functions=(forward_wn_to_wl, backward_wl_to_wn))
            ax3.set_xlabel(\"Wavelength ($\\mu m$)\", color='darkgreen', fontsize=12)
            ax3.tick_params(axis='x', labelcolor='darkgreen')
            
            # 图例合并
            lines_1, labels_1 = ax1.get_legend_handles_labels()
            lines_2, labels_2 = ax2.get_legend_handles_labels()
            ax1.legend(lines_1 + lines_2, labels_1 + labels_2, loc='upper right')
            
            ax1.set_title(f\"Mixture Spectrum (T={T}K, P={P}atm, Wing={omega_wing} cm$^{{-1}}$)\")
            ax1.grid(True, alpha=0.3)
            self.fig.tight_layout()
            self.canvas.draw()
            
            self.stats_text.setHtml(stats_msg)
            self.log(\"混合光谱计算完成！\")
        else:
            self.log(\"未能生成有效光谱。\")

        self.progress_bar.setVisible(False)

    def clear_plot(self):
        self.fig.clear()
        self.canvas.draw()
        self.stats_text.clear()

