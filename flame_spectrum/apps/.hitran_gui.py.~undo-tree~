            raise FileNotFoundError(f\"PAR file not found: {par_file_path}\")
        
        base_name = os.path.basename(par_file_path)
        # 优化文件名解析：支持 01_H2O.par 或 CO_1416.par
        mol_id = None
        if base_name[:2].isdigit():
            mol_id = int(base_name[:2])
        else:
