import numpy as np

from PyQt6.QtWidgets import (QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout,
                             QPushButton, QLabel, QLineEdit, QGroupBox, QFileDialog,
                             QMessageBox, QTextEdit, QCheckBox, QDoubleSpinBox,
                             QProgressBar, QSplitter, QListWidget, QAbstractItemView,
                             QFormLayout)
from PyQt6.QtCore import Qt

import matplotlib
matplotlib.use('QtAgg')
from matplotlib.backends.backend_qtagg import FigureCanvasQTAgg as FigureCanvas
from matplotlib.backends.backend_qtagg import NavigationToolbar2QT as NavigationToolbar
from matplotlib.figure import Figure

# 【关键】导入您的核心计算模块 (请确保路径正确，且 hitran_spectrum.py 已改为 PyQt6)
from core.hitran_spectrum import HitranSpectrum, SpectrumCalculationThread

class HitranGUI(QMainWindow):
    def __init__(self, initial_T=300.0, initial_P=1.0, db_path=\"\", cantera_species=None):
        super().__init__()
        
        # 数据库路径定位
        current_dir = os.path.dirname(os.path.abspath(__file__))
        project_root = os.path.dirname(current_dir) 
        self.db_path = db_path if db_path else os.path.join(project_root, 'hitran_database')
        if not os.path.exists(self.db_path):
            os.makedirs(self.db_path, exist_ok=True)
            
        self.cantera_species = cantera_species if cantera_species else {}
        self.global_min_wn = float('inf')
        self.global_max_wn = 0.0
        self.calc_thread = None # 用于存储后台计算线程
            
        self.init_ui(initial_T, initial_P)

    def init_ui(self, T, P):
        self.setWindowTitle('HITRAN 混合气体光谱仿真工具 (多线程双轴版)')
        self.setGeometry(100, 100, 1400, 900)
        central_widget = QWidget()
        self.setCentralWidget(central_widget)
        main_layout = QHBoxLayout()
        central_widget.setLayout(main_layout)

        main_layout.addWidget(self.create_control_panel(T, P), 1)
        main_layout.addWidget(self.create_right_panel(), 2)

    def create_control_panel(self, T, P):
        panel = QWidget()
        layout = QVBoxLayout()
        panel.setLayout(layout)

        # ---- 多文件选择 ----
        file_group = QGroupBox(\"HITRAN 文件选择 (支持多选)\")
        file_layout = QVBoxLayout()
        self.par_file_list = QListWidget()
        self.par_file_list.setSelectionMode(QAbstractItemView.SelectionMode.ExtendedSelection)
        file_layout.addWidget(self.par_file_list)
        
        btn_layout = QHBoxLayout()
        self.btn_add_par = QPushButton(\"添加 .par 文件\")
        self.btn_add_par.clicked.connect(self.add_par_files)
        btn_layout.addWidget(self.btn_add_par)
        self.btn_remove_par = QPushButton(\"移除选中\")
        self.btn_remove_par.clicked.connect(self.remove_selected_par)
        btn_layout.addWidget(self.btn_remove_par)
        file_layout.addLayout(btn_layout)
        file_group.setLayout(file_layout)
        layout.addWidget(file_group)

        # ---- 全局参数 ----
        param_group = QGroupBox(\"全局计算参数\")
        param_layout = QFormLayout()
        
        self.temp_spin = QDoubleSpinBox()
        self.temp_spin.setRange(100, 5000)
        self.temp_spin.setValue(T) 
        param_layout.addRow(\"温度 (K):\", self.temp_spin)
        
        self.pressure_spin = QDoubleSpinBox()
        self.pressure_spin.setRange(0.001, 100)
        self.pressure_spin.setValue(P) 
        param_layout.addRow(\"压力 (atm):\", self.pressure_spin)
        
        self.path_spin = QDoubleSpinBox()
        self.path_spin.setRange(0.1, 10000)
        self.path_spin.setValue(100.0)
        param_layout.addRow(\"光程 (cm):\", self.path_spin)

        self.omega_wing_spin = QDoubleSpinBox()
        self.omega_wing_spin.setRange(0.1, 500.0)
        self.omega_wing_spin.setValue(25.0)
        self.omega_wing_spin.setDecimals(1)
        param_layout.addRow(\"Omega Wing ($cm^{-1}$):\", self.omega_wing_spin)

        param_group.setLayout(param_layout)
        layout.addWidget(param_group)

        # ---- 波数范围 ----
        wn_group = QGroupBox(\"波数范围 (自动识别)\")
        wn_layout = QFormLayout()
        self.start_spin = QDoubleSpinBox()
        self.start_spin.setRange(0, 100000)
        self.start_spin.setValue(1000)
        self.start_spin.setDecimals(4)
        wn_layout.addRow(\"起始 ($cm^{-1}$):\", self.start_spin)
        
        self.end_spin = QDoubleSpinBox()
        self.end_spin.setRange(0, 100000)
        self.end_spin.setValue(5000)
        self.end_spin.setDecimals(4)
        wn_layout.addRow(\"结束 ($cm^{-1}$):\", self.end_spin)
        
        self.resolution_spin = QDoubleSpinBox()
        self.resolution_spin.setRange(0.0001, 1.0)
        self.resolution_spin.setValue(0.01)
        self.resolution_spin.setDecimals(4)
        wn_layout.addRow(\"分辨率 ($cm^{-1}$):\", self.resolution_spin)
        wn_group.setLayout(wn_layout)
        layout.addWidget(wn_group)

        self.progress_bar = QProgressBar()
        self.progress_bar.setRange(0, 0) # 0,0 表示无限循环动画
        self.progress_bar.setVisible(False)
        layout.addWidget(self.progress_bar)

        btn_calc_layout = QHBoxLayout()
        self.calc_btn = QPushButton(\"开始计算混合光谱\")
        self.calc_btn.setStyleSheet(\"background-color: #2196F3; color: white; font-weight: bold; padding: 8px;\")
        self.calc_btn.clicked.connect(self.start_calculation)
        btn_calc_layout.addWidget(self.calc_btn)
        
        self.clear_btn = QPushButton(\"清除图形\")
        self.clear_btn.clicked.connect(self.clear_plot)
        btn_calc_layout.addWidget(self.clear_btn)
        layout.addLayout(btn_calc_layout)

        info_db = QGroupBox(\"运行日志\")
        info_db_layout = QVBoxLayout()
        self.info_text = QTextEdit()
        self.info_text.setMaximumHeight(120)
        self.info_text.setReadOnly(True)
        info_db_layout.addWidget(self.info_text)
        info_db.setLayout(info_db_layout)
        layout.addWidget(info_db)
        
        layout.addStretch()
        return panel

    def create_right_panel(self):
        panel = QWidget()
        layout = QVBoxLayout()
        panel.setLayout(layout)
        splitter = QSplitter(Qt.Orientation.Vertical) 
        
        plot_widget = QWidget()
        plot_layout = QVBoxLayout()
        plot_widget.setLayout(plot_layout)
        
        self.fig = Figure(figsize=(10, 6), dpi=100)
        self.canvas = FigureCanvas(self.fig)
        self.toolbar = NavigationToolbar(self.canvas, self)
        plot_layout.addWidget(self.toolbar)
        plot_layout.addWidget(self.canvas)
        
        stats_widget = QWidget()
        stats_layout = QVBoxLayout()
        stats_widget.setLayout(stats_layout)
        stats_title = QLabel(\"计算结果统计\")
        stats_title.setStyleSheet(\"font-weight: bold; font-size: 14px; margin: 5px;\")
        stats_layout.addWidget(stats_title)
        self.stats_text = QTextEdit()
        self.stats_text.setMaximumHeight(150)
        self.stats_text.setReadOnly(True)
        stats_layout.addWidget(self.stats_text)
        
        splitter.addWidget(plot_widget)
        splitter.addWidget(stats_widget)
        splitter.setSizes([600, 150])
        layout.addWidget(splitter)
        return panel

    # ================= 文件选择与波数范围 =================
    def add_par_files(self):
        filenames, _ = QFileDialog.getOpenFileNames(
            self, \"选择 HITRAN .par 文件 (可多选)\", self.db_path, \"PAR Files (*.par);;All Files (*)\"
        )
        if filenames:
            existing = [self.par_file_list.item(i).text() for i in range(self.par_file_list.count())]
            for f in filenames:
                if f not in existing:
                    self.par_file_list.addItem(f)
                    self.update_wn_range_from_par(f)
                    
            if self.global_min_wn != float('inf'):
                self.start_spin.setValue(self.global_min_wn)
                self.end_spin.setValue(self.global_max_wn)
                self.log(f\"已自动更新波数范围: {self.global_min_wn:.2f} - {self.global_max_wn:.2f} cm^-1\")

    def update_wn_range_from_par(self, par_file):
        try:
            with open(par_file, 'r') as f:
                for line in f:
                    if len(line) >= 15:
                        try:
                            wn = float(line[3:15].strip())
                            if wn < self.global_min_wn: self.global_min_wn = wn
                            if wn > self.global_max_wn: self.global_max_wn = wn
                        except ValueError:
                            continue
        except Exception as e:
            self.log(f\"警告: 无法读取 {os.path.basename(par_file)} 的波数范围 ({e})\")

    def remove_selected_par(self):
        for item in self.par_file_list.selectedItems():
            self.par_file_list.takeItem(self.par_file_list.row(item))
        if self.par_file_list.count() == 0:
            self.global_min_wn = float('inf')
            self.global_max_wn = 0.0

    def log(self, msg):
        self.info_text.append(msg)

    # ================= 【核心】多线程计算调用 =================
    def start_calculation(self):
        if self.par_file_list.count() == 0:
            QMessageBox.warning(self, \"警告\", \"请至少添加一个 .par 文件！\")
            return

        # 1. 初始化核心引擎
        hitran_engine = HitranSpectrum()
        
        # 2. 遍历文件，添加分子
        for i in range(self.par_file_list.count()):
            par_file = self.par_file_list.item(i).text()
            file_name = os.path.basename(par_file)
            mol_name = os.path.splitext(file_name)[0].split('_')[0] 
            
            # 智能浓度匹配 (注意：核心模块需要的是 摩尔分数 0~1，而不是 ppm)
            mole_fraction = 10.0e-6 # 默认 10 ppm
            if self.cantera_species:
                for sp, frac in self.cantera_species.items():
                    if mol_name.upper() in sp.upper() or sp.upper() in mol_name.upper():
                        mole_fraction = float(frac) # 直接使用摩尔分数
                        break
            
            try:
                hitran_engine.add_molecule(par_file, mole_fraction, name=mol_name)
                self.log(f\"已加载: {mol_name} (浓度: {mole_fraction*1e6:.2f} ppm)\")
            except Exception as e:
                self.log(f\"错误: 加载 {file_name} 失败 -> {str(e)}\")

        if not hitran_engine.molecules:
            QMessageBox.critical(self, \"错误\", \"没有成功加载任何分子，请检查 .par 文件格式！\")
            return

        # 3. 准备计算参数
        params = {
            'start': self.start_spin.value(),
            'end': self.end_spin.value(),
            'T': self.temp_spin.value(),
            'p': self.pressure_spin.value(),
            'l': self.path_spin.value(),
            'resolution': self.resolution_spin.value(),
            'omega_wing': self.omega_wing_spin.value()
        }

        # 4. 启动后台线程 (防止 UI 卡死)
        self.calc_btn.setEnabled(False)
        self.progress_bar.setVisible(True)
        self.log(\"开始后台计算光谱，请稍候...\")
        
        self.calc_thread = SpectrumCalculationThread(hitran_engine, params)
        self.calc_thread.finished.connect(self.on_calculation_finished)
        self.calc_thread.error.connect(self.on_calculation_error)
        self.calc_thread.start()

    def on_calculation_error(self, error_msg):
        self.progress_bar.setVisible(False)
        self.calc_btn.setEnabled(True)
        QMessageBox.critical(self, \"计算错误\", error_msg)
        self.log(f\"计算失败: {error_msg}\")

    # ================= 【核心】接收结果并绘制双轴图 =================
    def on_calculation_finished(self, results):
        self.progress_bar.setVisible(False)
        self.calc_btn.setEnabled(True)
        self.log(\"光谱计算完成！正在绘图...\")

        wavenumber = results['wavenumber']
        total_coef = results['total_coef']
        individual_coefs = results['individual_coefs']
        transmittance = results['Tr']
        params = results['params']
        
        # 清空并重建双X双Y轴
        self.fig.clear()
        ax1 = self.fig.add_subplot(111) 
        
        # 1. 主 Y 轴 (左侧): 透过率 (Transmittance)
        ax1.plot(wavenumber, transmittance, 'b-', linewidth=1.5, label=\"Transmittance (Total)\")
        ax1.set_xlabel(\"Wavenumber (cm$^{-1}$)\", color='black', fontsize=12)
        ax1.set_ylabel(\"Transmittance\", color='blue', fontsize=12)
        ax1.tick_params(axis='y', labelcolor='blue')
        ax1.set_ylim(-0.05, 1.1)
        
        # 2. 副 Y 轴 (右侧): 吸收系数 (Absorption Coefficient)
        ax2 = ax1.twinx()
        ax2.plot(wavenumber, total_coef, 'r--', linewidth=1.5, alpha=0.7, label=\"Abs. Coeff (Total)\")
        
        # 绘制单个分子的吸收系数贡献 (虚线)
        colors = ['orange', 'green', 'purple', 'brown', 'pink']
        for idx, (mol_name, coef) in enumerate(individual_coefs.items()):
            color = colors[idx % len(colors)]
            ax2.plot(wavenumber, coef, '--', color=color, alpha=0.6, linewidth=1.0, label=f\"Abs. Coeff ({mol_name})\")
            
        ax2.set_ylabel(\"Absorption Coefficient\", color='red', fontsize=12)
        ax2.tick_params(axis='y', labelcolor='red')
        
        # 3. 副 X 轴 (顶部): 波长 (Wavelength in \\mu m)
        def forward_wn_to_wl(x):
            x = np.where(x == 0, 1e-10, x)
            return 10000.0 / x
        def backward_wl_to_wn(x):
            x = np.where(x == 0, 1e-10, x)
            return 10000.0 / x

        ax3 = ax1.secondary_xaxis('top', functions=(forward_wn_to_wl, backward_wl_to_wn))
        ax3.set_xlabel(r\"Wavelength ($\\mu m$)\", color='darkgreen', fontsize=12)
        ax3.tick_params(axis='x', labelcolor='darkgreen')
        
        # 图例合并
        lines_1, labels_1 = ax1.get_legend_handles_labels()
        lines_2, labels_2 = ax2.get_legend_handles_labels()
        ax1.legend(lines_1 + lines_2, labels_1 + labels_2, loc='upper right', fontsize='small')
        
        T, p, l, wing = params['T'], params['p'], params['l'], params['omega_wing']
        ax1.set_title(f\"Mixture Spectrum (T={T}K, P={p}atm, L={l}cm, Wing={wing} cm$^{{-1}}$)\")
        ax1.grid(True, alpha=0.3)
        self.fig.tight_layout()
        self.canvas.draw()
        
        # 更新统计信息
        stats_msg = f\"<b>计算参数:</b> T={T}K, P={p}atm, L={l}cm<br><b>包含分子:</b><br>\"
        for mol_name in individual_coefs.keys():
            stats_msg += f\"- {mol_name}<br>\"
        self.stats_text.setHtml(stats_msg)

    def clear_plot(self):
        self.fig.clear()
        self.canvas.draw()
        self.stats_text.clear()

if __name__ == '__main__':
