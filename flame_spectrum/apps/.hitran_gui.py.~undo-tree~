    def __init__(self, q_folder_path=\"\"):
        self.molecules = [] 
        # 标准 HITRAN 分子 ID 映射表
        self.mol_map = {
            1: 'H2O', 2: 'CO2', 3: 'O3', 4: 'N2O', 5: 'CO', 
            6: 'CH4', 7: 'O2', 8: 'NO', 9: 'SO2', 10: 'NO2'
        }
        self.reverse_mol_map = {v: k for k, v in self.mol_map.items()}
        
        self.q_folder_path = q_folder_path
        self.q_data = {} # 缓存配分函数数据 {mol_id: {isotopologue: {T: Q}}}

    def set_q_folder(self, folder_path):
        \"\"\"设置并加载配分函数文件夹\"\"\"
        self.q_folder_path = folder_path
        if os.path.exists(folder_path):
            self._load_all_q_files()

    def _load_all_q_files(self):
        \"\"\"内部方法：扫描文件夹并解析所有 q*.txt 文件\"\"\"
        for filename in os.listdir(self.q_folder_path):
            if filename.startswith('q') and filename.endswith('.txt'):
                # 提取分子 ID，例如 q1.txt -> 1, q02.txt -> 2
                match = re.search(r'q(\\d+)\\.txt', filename)
                if match:
                    mol_id = int(match.group(1))
                    filepath = os.path.join(self.q_folder_path, filename)
                    self.q_data[mol_id] = self._parse_q_file(filepath)

    def _parse_q_file(self, filepath):
        \"\"\"解析单个 q 文件，返回 {isotopologue_index: {T: Q}}\"\"\"
        q_dict = {}
        try:
            with open(filepath, 'r') as f:
                for line in f:
                    parts = line.split()
                    if len(parts) >= 8:
                        iso = int(parts[0])
                        # 标准 q 文件格式: ISO, 70, 73, 78, 82, 87, 94, 98, 105, 115, 125...
                        # 这里假设包含 296K, 500K, 1000K, 1500K, 2000K 等标准温度节点
                        # 具体索引取决于您的 q 文件版本，这里以 HITRAN 常见格式为例：
                        # 通常: T=296(idx 4), 500(5), 1000(6), 1500(7), 2000(8), 2500(9), 3000(10)
                        temps = [296.0, 500.0, 1000.0, 1500.0, 2000.0, 2500.0, 3000.0]
                        q_vals = [float(parts[i]) for i in range(4, 11) if i < len(parts)]
                        
                        if len(temps) == len(q_vals):
