                else:
                    # 如果波数网格不完全一致，可能需要插值 (这里假设网格一致)
                    total_absorbance += abs_coeff * L

                # 绘制单个分子的贡献 (虚线)
                self.ax.plot(wn, abs_coeff * L, '--', alpha=0.6, label=f\"{mol_name} ({concentration_ppm:.1f} ppm)\")
                
                stats_msg += f\"- <b>{mol_name}</b>: {concentration_ppm:.2f} ppm<br>\"
                
            except Exception as e:
                self.log(f\"错误: 处理 {file_name} 失败 -> {str(e)}\")
                stats_msg += f\"- <font color='red'>{file_name} 计算失败</font><br>\"

            self.progress_bar.setValue(int((i + 1) / total_files * 100))

        # 绘制总吸收光谱 (实线)
        if total_absorbance is not None:
            self.ax.plot(wavenumbers, total_absorbance, 'k-', linewidth=2, label=\"Total Mixture\")
            self.ax.set_xlabel(\"Wavenumber (cm$^{-1}$)\")
            self.ax.set_ylabel(\"Absorbance\")
            self.ax.set_title(f\"Mixture Spectrum at {T} K, {P} atm\")
            self.ax.legend()
            self.ax.grid(True, alpha=0.3)
            self.canvas.draw()
            self.stats_text.setHtml(stats_msg)
            self.log(\"混合光谱计算完成！\")
        else:
            self.log(\"未能生成有效光谱。\")

        self.progress_bar.setVisible(False)

