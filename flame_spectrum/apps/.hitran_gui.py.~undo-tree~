        return q_dict

    def _get_q_ratio(self, mol_id, iso_id, T):
        \"\"\"获取配分函数比值 Q(T_ref)/Q(T)\"\"\"
        T_ref = 296.0
        if mol_id in self.q_data and iso_id in self.q_data[mol_id]:
            q_dict = self.q_data[mol_id][iso_id]
            q_ref = q_dict.get(T_ref, 0)
            
