            par_file = self.par_file_list.item(i).text()
            file_name = os.path.basename(par_file)
            self.log(f\"正在处理: {file_name} ...\")
            
            mol_name = os.path.splitext(file_name)[0].split('_')[0] 
            
            concentration_ppm = 10.0 
            if self.cantera_species:
                for sp, frac in self.cantera_species.items():
