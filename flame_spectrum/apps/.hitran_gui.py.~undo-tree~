        h = 6.62607015e-34
        c_light = 2.99792458e10
        T_ref = 296.0
        p_ref = 1.0
        
        p_pa = p * 101325.0
        N_total = (p_pa / (k_B * T)) * 1e-6 
        
        for mol in self.molecules:
            mol_coef = np.zeros_like(wavenumber)
            c = mol['conc']
            valid_lines = [ln for ln in mol['lines'] if wn_start - omega_wing <= ln['v0'] <= wn_end + omega_wing]
            
            for ln in valid_lines:
                v0 = ln['v0']
                sw_ref = ln['sw']
                
                # 【核心修复】调用真实的配分函数 Q 计算
                q_ratio = self._get_q_ratio(ln['molecule_id'], ln['iso_id'], T)
                
                exp_ratio = np.exp(-h * c_light * ln['elower'] / k_B * (1/T - 1/T_ref))
                stim_ratio = (1 - np.exp(-h * c_light * v0 / (k_B * T))) / (1 - np.exp(-h * c_light * v0 / (k_B * T_ref)))
                sw_T = sw_ref * q_ratio * exp_ratio * stim_ratio
                
