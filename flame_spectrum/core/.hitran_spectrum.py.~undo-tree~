import numpy as np
from scipy.special import voigt_profile

class HitranSpectrum:
    def __init__(self, par_file_path=None, molecule_id=None):
        self.par_file_path = par_file_path
        self.molecule_id = molecule_id
        self.lines = []
        self.molecule_info = {}
        if par_file_path:
            self.load_par_file(par_file_path)

    def load_par_file(self, filepath):
        \"\"\"解析 HITRAN .par 文件\"\"\"
        self.par_file_path = filepath
        self.lines = []
        if not os.path.exists(filepath):
            raise FileNotFoundError(f\"PAR file not found: {filepath}\")

        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                if len(line.strip()) < 100: continue
                try:
                    mol_id = int(line[0:2].strip())
                    if self.molecule_id and mol_id != self.molecule_id: continue
                    
                    self.lines.append({
                        'molecule_id': mol_id,
                        'v0': float(line[3:15].strip()),
                        'sw': float(line[15:25].strip()),
                        'gamma_air': float(line[35:40].strip()),
                        'gamma_self': float(line[40:45].strip()),
                        'n_air': float(line[50:54].strip()),
                        'elower': float(line[55:65].strip())
                    })
                except ValueError:
                    continue
        
        if not self.lines:
            raise ValueError(f\"No valid lines found in {filepath}\")
        
        # 简单映射分子名称
        mol_map = {1: 'H2O', 2: 'CO2', 3: 'O3', 4: 'N2O', 5: 'CO', 8: 'NO', 10: 'NO2'}
        self.molecule_info = {'molecule_name': mol_map.get(self.molecule_id, f'Mol_{self.molecule_id}')}

    def calculate_spectrum(self, wn_start, wn_end, T, p, l, c, resolution=0.01):
        \"\"\"计算吸收系数和透射率\"\"\"
        if not self.lines:
            raise ValueError(\"No spectral lines loaded.\")

        wavenumber = np.arange(wn_start, wn_end, resolution)
        coef = np.zeros_like(wavenumber)
        
        # 过滤波段内的谱线 (考虑线宽扩展)
        margin = 2.0 
        valid_lines = [ln for ln in self.lines if wn_start - margin <= ln['v0'] <= wn_end + margin]

        k_B = 1.380649e-23
        h = 6.62607015e-34
        c_light = 2.99792458e10
        T_ref = 296.0
        p_ref = 1.0
        
        p_pa = p * 101325.0
        N_total = (p_pa / (k_B * T)) * 1e-6 

        for ln in valid_lines:
            v0 = ln['v0']
            sw_ref = ln['sw']
            
            # 温度修正线强
            q_ratio = (T_ref / T) ** 1.5 
            exp_ratio = np.exp(-h * c_light * ln['elower'] / k_B * (1/T - 1/T_ref))
            stim_ratio = (1 - np.exp(-h * c_light * v0 / (k_B * T))) / (1 - np.exp(-h * c_light * v0 / (k_B * T_ref)))
            sw_T = sw_ref * q_ratio * exp_ratio * stim_ratio

            # 计算 Voigt 线型参数
            gamma_L = ln['gamma_air'] * (p_ref / p) * (T_ref / T) ** ln['n_air']
            gamma_D = v0 / c_light * np.sqrt(2 * k_B * T * np.log(2) / (18.015 * 1.660539e-27)) 
            
            # 累加吸收系数
            profile = voigt_profile(wavenumber - v0, gamma_D, gamma_L)
            coef += sw_T * N_total * c * profile * c_light

        # 计算透射率 (Beer-Lambert Law)
        transmittance = np.exp(-coef * l)
        
        return {
            'wavenumber': wavenumber,
            'coef': coef,
            'Tr': transmittance,
            'params': {'T': T, 'p': p, 'l': l, 'c': c}
        }
