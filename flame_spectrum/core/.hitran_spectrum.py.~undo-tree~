import os
import numpy as np
from scipy.special import voigt_profile
from PyQt6.QtCore import QThread, pyqtSignal

class HitranSpectrum:
    \"\"\"多分子 HITRAN 光谱计算管理器\"\"\"
    def __init__(self):
        self.molecules = [] # 存储分子列表: [{'name': str, 'lines': list, 'conc': float}, ...]
        self.mol_map = {1: 'H2O', 2: 'CO2', 3: 'O3', 4: 'N2O', 5: 'CO', 8: 'NO', 10: 'NO2'}

    def add_molecule(self, par_file_path, concentration, name=None):
        \"\"\"添加一种分子及其浓度 (摩尔分数)\"\"\"
        if not os.path.exists(par_file_path):
            raise FileNotFoundError(f\"PAR file not found: {par_file_path}\")
        
        # 尝试从文件名推断 mol_id，例如 '01_H2O.par' -> 1
        base_name = os.path.basename(par_file_path)
        mol_id = int(base_name[:2]) if base_name[:2].isdigit() else None
            
        lines = self._load_par_file(par_file_path, mol_id)
        if not lines:
            raise ValueError(f\"No valid lines found in {par_file_path}\")
            
        mol_name = name or self.mol_map.get(mol_id, f'Mol_{mol_id}')
        
        # 避免重复添加同种分子
        self.molecules = [m for m in self.molecules if m['name'] != mol_name]
        self.molecules.append({
            'name': mol_name,
            'lines': lines,
            'conc': concentration
        })

    def _load_par_file(self, filepath, target_mol_id=None):
        \"\"\"内部方法：解析 HITRAN .par 文件\"\"\"
        lines = []
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                if len(line.strip()) < 100: continue
                try:
                    mol_id = int(line[0:2].strip())
                    if target_mol_id and mol_id != target_mol_id: continue
                    
                    lines.append({
                        'molecule_id': mol_id,
                        'v0': float(line[3:15].strip()),
                        'sw': float(line[15:25].strip()),
                        'gamma_air': float(line[35:40].strip()),
                        'n_air': float(line[50:54].strip()),
                        'elower': float(line[55:65].strip())
                    })
                except ValueError:
                    continue
        return lines

    def calculate_spectrum(self, wn_start, wn_end, T, p, l, resolution=0.01, omega_wing=25.0):
        \"\"\"
        计算多组分混合气体的吸收光谱
        :return: dict 包含 wavenumber, total_coef, individual_coefs, Tr, params
        \"\"\"
        if not self.molecules:
            raise ValueError(\"No molecules added. Use add_molecule() first.\")

        wavenumber = np.arange(wn_start, wn_end, resolution)
        total_coef = np.zeros_like(wavenumber)
        individual_coefs = {}
        
        # 物理常数
        k_B = 1.380649e-23
        h = 6.62607015e-34
        c_light = 2.99792458e10
        T_ref = 296.0
        p_ref = 1.0
        
        p_pa = p * 101325.0
        N_total = (p_pa / (k_B * T)) * 1e-6  # 数密度 (cm^-3)
        
        for mol in self.molecules:
            mol_coef = np.zeros_like(wavenumber)
            c = mol['conc']
            
            # 过滤波段内的谱线 (考虑线翼扩展)
            valid_lines = [ln for ln in mol['lines'] if wn_start - omega_wing <= ln['v0'] <= wn_end + omega_wing]
            
            for ln in valid_lines:
                v0 = ln['v0']
                sw_ref = ln['sw']
                
                # 温度修正线强
                q_ratio = (T_ref / T) ** 1.5 
                exp_ratio = np.exp(-h * c_light * ln['elower'] / k_B * (1/T - 1/T_ref))
                stim_ratio = (1 - np.exp(-h * c_light * v0 / (k_B * T))) / (1 - np.exp(-h * c_light * v0 / (k_B * T_ref)))
                sw_T = sw_ref * q_ratio * exp_ratio * stim_ratio
                
                # 计算 Voigt 线型参数
                gamma_L = ln['gamma_air'] * (p_ref / p) * (T_ref / T) ** ln['n_air']
                # 简化多普勒展宽计算 (假设平均分子量，此处用 20 g/mol 近似)
                gamma_D = v0 / c_light * np.sqrt(2 * k_B * T * np.log(2) / (20.0 * 1.660539e-27)) 
                
                # 累加吸收系数
                profile = voigt_profile(wavenumber - v0, gamma_D, gamma_L)
                mol_coef += sw_T * N_total * c * profile * c_light
                
            individual_coefs[mol['name']] = mol_coef
            total_coef += mol_coef

        # 计算透射率 (Beer-Lambert Law)
        transmittance = np.exp(-total_coef * l)
        
        return {
            'wavenumber': wavenumber,
            'total_coef': total_coef,
            'individual_coefs': individual_coefs,
            'Tr': transmittance,
            'params': {'T': T, 'p': p, 'l': l, 'wn_range': (wn_start, wn_end)}
        }


class SpectrumCalculationThread(QThread):
    \"\"\"后台多线程计算光谱，防止 UI 卡死\"\"\"
    finished = pyqtSignal(dict)
    error = pyqtSignal(str)

    def __init__(self, hitran_engine, params, parent=None):
        super().__init__(parent)
        self.hitran_engine = hitran_engine
        self.params = params

    def run(self):
        try:
            results = self.hitran_engine.calculate_spectrum(
                wn_start=self.params['start'],
                wn_end=self.params['end'],
                T=self.params['T'],
                p=self.params['p'],
                l=self.params['l'],
                resolution=self.params.get('resolution', 0.02),
                omega_wing=self.params.get('omega_wing', 25.0)
            )
            results['params'].update(self.params) # 合并参数
            self.finished.emit(results)
