            c = mol['conc']
            valid_lines = [ln for ln in mol['lines'] if wn_start - omega_wing <= ln['v0'] <= wn_end + omega_wing]
            
            for ln in valid_lines:
                v0 = ln['v0']
                sw_ref = ln['sw']
                
                # 【核心修复】调用真实的配分函数 Q 计算
